{
  "program_id": "standard_wash",
  "program_name": "standard wash",
  "revision": 1,
  "enabled": true,
  "default_segment_timeout_ms": 15000,
  "default_exit_timeout_ms": 5000,
  "segments": [
    {
      "segment_id": "standard_roof",
      "segment_name": "roof brush",
      "sequence_no": 1,
      "segment_kind": "roof_brush",
      "motion_plan": {
        "direction": "forward",
        "target_reference": "tail",
        "target_tolerance_mm": 50,
        "requires_position_feedback": true
      },
      "continuous_controls": {
        "roof_brush_follow": true,
        "side_brush_enabled": false,
        "ro_water_enabled": false,
        "dryer_enabled": false
      },
      "conditional_controls": [
        {
          "control_id": "standard_roof_chemical",
          "control_object": "chemical",
          "basis": "absolute_mm",
          "start_trigger": {
            "reference": "absolute_mm",
            "compare_mode": "greater_equal",
            "value_mm": 0,
            "tolerance_mm": 0
          },
          "stop_trigger": {
            "reference": "absolute_mm",
            "compare_mode": "greater_equal",
            "value_mm": 9000,
            "tolerance_mm": 0
          },
          "active_during_exit": false
        }
      ],
      "completion_condition": {
        "reference": "tail_reached",
        "compare_mode": "true"
      },
      "exit_actions": {
        "stop_roof_brush": true,
        "stop_chemical": true,
        "roof_brush_home": true
      }
    },
    {
      "segment_id": "standard_side",
      "segment_name": "side brush",
      "sequence_no": 2,
      "segment_kind": "side_brush",
      "motion_plan": {
        "direction": "reverse",
        "target_reference": "head",
        "target_tolerance_mm": 50,
        "requires_position_feedback": true
      },
      "continuous_controls": {
        "roof_brush_follow": false,
        "side_brush_enabled": true,
        "ro_water_enabled": false,
        "dryer_enabled": false
      },
      "conditional_controls": [
        {
          "control_id": "standard_side_chemical",
          "control_object": "chemical",
          "basis": "absolute_mm",
          "start_trigger": {
            "reference": "absolute_mm",
            "compare_mode": "greater_equal",
            "value_mm": 3000,
            "tolerance_mm": 0
          },
          "stop_trigger": {
            "reference": "absolute_mm",
            "compare_mode": "greater_equal",
            "value_mm": 7000,
            "tolerance_mm": 0
          },
          "active_during_exit": false
        }
      ],
      "completion_condition": {
        "reference": "head_reached",
        "compare_mode": "true"
      },
      "exit_actions": {
        "stop_side_brush": true,
        "stop_chemical": true
      }
    },
    {
      "segment_id": "standard_ro",
      "segment_name": "ro water",
      "sequence_no": 3,
      "segment_kind": "ro_water",
      "motion_plan": {
        "direction": "forward",
        "target_reference": "tail",
        "target_tolerance_mm": 50,
        "requires_position_feedback": true
      },
      "continuous_controls": {
        "roof_brush_follow": false,
        "side_brush_enabled": false,
        "ro_water_enabled": true,
        "dryer_enabled": false
      },
      "conditional_controls": [],
      "completion_condition": {
        "reference": "tail_reached",
        "compare_mode": "true"
      },
      "exit_actions": {
        "close_ro_water": true
      }
    },
    {
      "segment_id": "standard_dryer",
      "segment_name": "dryer",
      "sequence_no": 4,
      "segment_kind": "dryer",
      "motion_plan": {
        "direction": "reverse",
        "target_reference": "head",
        "target_tolerance_mm": 50,
        "requires_position_feedback": true
      },
      "continuous_controls": {
        "roof_brush_follow": false,
        "side_brush_enabled": false,
        "ro_water_enabled": false,
        "dryer_enabled": true
      },
      "conditional_controls": [],
      "completion_condition": {
        "reference": "head_reached",
        "compare_mode": "true"
      },
      "exit_actions": {
        "close_dryer": true
      }
    }
  ]
}
